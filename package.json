{
  "name": "trezor-algorand-js",
  "version": "0.1.0",
  "description": "Browser-first host library for signing Algorand transactions with Trezor devices running the forked firmware.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./webusb": {
      "types": "./dist/webusb/index.d.ts",
      "import": "./dist/webusb/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/w3c-web-usb": "^1.0.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
